{
  "ReverseProxy": {
    "Routes": {
      "parkinglot-route": {
        "ClusterId": "parkinglot-cluster",
        "Match": {
          "Path": "/parking/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "slot-route": {
        "ClusterId": "slot-cluster",
        "Match": {
          "Path": "/slot/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "ticket-route": {
        "ClusterId": "ticket-cluster",
        "Match": {
          "Path": "/ticket/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/payment/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "parkinglot-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5185/"
          }
        }
      },
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5195/"
          }
        }
      },
      "slot-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5100/"
          }
        }
      },
      "ticket-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005/"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}